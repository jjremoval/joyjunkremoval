#!/bin/sh
# Auto-log every commit into CHANGELOG.md and fold the entry INTO that same
# commit via --amend, so history stays one-commit-per-change.
#
# Loop-safe: the amend re-fires this hook, but by then the entry is already in
# CHANGELOG.md, so the grep guard below makes us exit before amending again.
# The amend runs locally at commit time (before any push), so the SHA rewrite
# is harmless. --no-verify on the amend skips pre-commit/commit-msg (not this).

MSG=$(git log -1 --pretty=%s)

# Skip merges / reverts — not real site changes.
case "$MSG" in
  Merge*|merge*|Revert*|revert*) exit 0 ;;
esac

# Only act from the repo root, where CHANGELOG.md lives.
[ -f CHANGELOG.md ] || exit 0

DATE=$(date +%Y-%m-%d)
ENTRY="- $DATE: $MSG"

# Already logged -> this is the amend re-fire; stop here (breaks the loop).
# The `--` is required: the entry starts with "-" and would otherwise look like
# a grep flag.
grep -qF -- "$ENTRY" CHANGELOG.md && exit 0

# Prepend the entry under the "## [Unreleased]" heading (newest first).
python3 - "$ENTRY" <<'PY'
import sys
entry = sys.argv[1]
with open('CHANGELOG.md') as f:
    content = f.read()
needle = '## [Unreleased]\n'
if needle in content:
    content = content.replace(needle, needle + entry + '\n', 1)
    with open('CHANGELOG.md', 'w') as f:
        f.write(content)
PY

git add CHANGELOG.md
git commit --amend --no-edit --no-verify >/dev/null 2>&1
